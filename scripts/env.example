# Copy to .env.local for local dev — never commit real secrets.
# Vercel project: protoportal-admin

# ── Portal Supabase (auth + orders + site config storage) ──
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ── Stock Supabase (catalogue, products SOH, image gen locks) ──
VITE_STOCK_SUPABASE_URL=
VITE_STOCK_SUPABASE_KEY=

# ── Admin API auth ──
# Optional automation key (x-admin-key header); primary auth is Supabase JWT allowlist
ADMIN_DASH_KEY=
CRON_SECRET=
ORDER_NOTIFY_SECRET=

# ── OpenRouter (Apollo + image generation) ──
OPENROUTER_API_KEY=
OPENROUTER_IMAGE_MODEL=google/gemini-3-pro-image-preview
OPENROUTER_IMAGE_MODEL_FAST=google/gemini-2.5-flash-image
IMAGE_GEN_CONCURRENCY=3

# ── Brevo (order confirmation email + CRM sync) ──
BREVO_API_KEY=
BREVO_SENDER_EMAIL=online@proto.co.za

# ── Cloudflare R2 (optional live image CDN) ──
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=proto-images
R2_PUBLIC_BASE_URL=

# ── Nutstore WebDAV (Product Loader) ──
NUTSTORE_WEBDAV_URL=https://dav.jianguoyun.com/dav/
# Preferred names (also accepts NUTSTORE_WEBDAV_USER / NUTSTORE_WEBDAV_PASSWORD / NUTSTORE_PHOTOS_ROOT)
NUTSTORE_USER=
NUTSTORE_APP_PASSWORD=
NUTSTORE_PHOTOS_ROOT=/PTR-photos
# Legacy aliases also supported: NUTSTORE_WEBDAV_USER, NUTSTORE_WEBDAV_PASSWORD

# ── BLADERUNNER / ERP scripts (not required on Vercel admin) ──
SUPABASE_URL=https://yiqsvwajozafvalwcero.supabase.co
SQL_SERVER=BLADERUNNER-PC
SQL_DATABASE=POSWINSQL
SQL_USER=ProtoSyncReadOnly
SQL_PASSWORD=
SUPABASE_TABLE=products
WEBSITE_STOCK_TABLE=website_stock
SUPABASE_STORAGE_BUCKET=product-images
IMAGE_INTAKE_FOLDER=C:\script\NewImages
IMAGE_INTAKE_PROCESSED_FOLDER=C:\script\ProcessedImages
IMAGE_INTAKE_FAILED_FOLDER=C:\script\FailedImages
DRY_RUN=true
IMAGE_INTAKE_MAX_FILES=3
SUPABASE_PAGE_SIZE=1000
