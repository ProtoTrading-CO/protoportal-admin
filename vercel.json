{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "rewrites": [
    { "source": "/((?!api/|assets/).*)", "destination": "/index.html" }
  ],
  "headers": [
    { "source": "/assets/(.*)", "headers": [{ "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }] },
    { "source": "/((?!assets/).*)", "headers": [{ "key": "Cache-Control", "value": "no-cache, must-revalidate" }] }
  ],
  "functions": {
    "api/seed-proto-active-customers.js": {
      "includeFiles": "data/proto-active-customers.json"
    },
    "api/image-intake.js": {
      "maxDuration": 60
    },
    "api/reprocess-live-to-dormant.js": {
      "maxDuration": 60
    },
    "api/apply-dormant-live.js": {
      "maxDuration": 60
    },
    "api/stock-actions.js": {
      "maxDuration": 60
    },
    "api/category-sort-order.js": {
      "maxDuration": 30
    },
    "api/catalog.js": {
      "maxDuration": 60
    },
    "api/bulk-products.js": {
      "maxDuration": 60
    },
    "api/approve-customers-bulk.js": {
      "maxDuration": 60
    },
    "api/nutstore-batch-lookup.js": {
      "maxDuration": 30
    },
    "api/nutstore-process.js": {
      "maxDuration": 60
    },
    "api/bulk-image-replace.js": {
      "maxDuration": 60
    },
    "api/apply-category-moves.js": {
      "maxDuration": 300,
      "includeFiles": "data/category-move-*.xlsx"
    }
  },
  "crons": [
    { "path": "/api/order-notify-sweep", "schedule": "*/10 * * * *" },
    { "path": "/api/run-scheduled-broadcasts", "schedule": "0 * * * *" },
    { "path": "/api/brevo-sync", "schedule": "*/15 * * * *" },
    { "path": "/api/purge-expired-staging", "schedule": "0 3 * * *" },
    { "path": "/api/image-gen-budget-check", "schedule": "0 8 * * *" }
  ]
}
